# Application
GO_ENV=development
PORT=3131
DB_MAX_POOL=10

# JWT
AUTH_TOKEN_EXPIRED_IN_MINUTES=15
REFRESH_TOKEN_EXPIRED_IN_DAYS=7
AUTH_TOKEN_SECRET_KEY=change-me-access-secret-min-32-chars
REFRESH_TOKEN_SECRET_KEY=change-me-refresh-secret-min-32-chars

# Database DSN (MySQL existing — local or cloud)
DB_URL=user:password@tcp(host:3306)/dbname?charset=utf8mb4&parseTime=True&loc=Local
