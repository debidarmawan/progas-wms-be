# Application (nginx :3131 → backend :3131)
GO_ENV=production
PORT=3131
DB_MAX_POOL=10

# JWT
AUTH_TOKEN_EXPIRED_IN_MINUTES=15
REFRESH_TOKEN_EXPIRED_IN_DAYS=7
AUTH_TOKEN_SECRET_KEY=change-me-access-secret-min-32-chars
REFRESH_TOKEN_SECRET_KEY=change-me-refresh-secret-min-32-chars

# --- Docker MySQL (stack VPS / lokal tanpa Aiven) ---
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=progas_wms
MYSQL_USER=progas_app
MYSQL_PASSWORD=change-me-app-password
MYSQL_PORT=3306
# 127.0.0.1 = aman; akses DBeaver via SSH tunnel. 0.0.0.0 = langsung dari internet (batasi firewall!).
MYSQL_BIND=127.0.0.1

# Hostname "mysql" = nama service di docker-compose (bukan localhost)
DB_URL=progas_app:change-me-app-password@tcp(mysql:3306)/progas_wms?charset=utf8mb4&parseTime=True&loc=Local

# --- Aiven / MySQL eksternal (tanpa service mysql di compose) ---
# Jalankan hanya: docker compose up backend nginx  (tanpa mysql)
# DB_URL=user:pass@tcp(host:3306)/dbname?charset=utf8mb4&parseTime=True&loc=Local&tls=skip-verify
