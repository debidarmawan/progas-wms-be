# Salin: cp .env.example .env && nano .env

PUBLIC_HOST=103-169-206-116.domainesia.io
API_PUBLIC_URL=http://103-169-206-116.domainesia.io/api/v1

# --- MySQL Aiven DEV (open access) ---
# Tidak perlu whitelist IP VPS, tidak perlu ca.pem.
# Ambil Host / Port / User / Password / Database dari Aiven Console.
#
# Format Go (bukan mysql://):
DB_URL=avnadmin:PASSWORD@tcp(mysql-xxxx.a.aivencloud.com:12345/defaultdb?charset=utf8mb4&parseTime=True&loc=UTC&tls=skip-verify

# Kosongkan untuk dev open access (default)
DB_CA_CERT=

# --- Production (opsional, jika pakai CA resmi Aiven) ---
# DB_URL=...&tls=aiven
# DB_CA_CERT=/app/certs/ca.pem
# Lalu mount volume certs di docker-compose dan letakkan ca.pem di deploy/certs/

# --- Backend ---
GO_ENV=production
PORT=3131
DB_MAX_POOL=5

AUTH_TOKEN_EXPIRED_IN_MINUTES=15
REFRESH_TOKEN_EXPIRED_IN_DAYS=7
AUTH_TOKEN_SECRET_KEY=
REFRESH_TOKEN_SECRET_KEY=

BOOTSTRAP_ADMIN_EMAIL=admin@progas.local
BOOTSTRAP_ADMIN_NAME=Superadmin
BOOTSTRAP_ADMIN_PASSWORD=GANTI_PASSWORD_ADMIN_KUAT
