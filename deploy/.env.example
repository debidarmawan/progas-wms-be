# Salin: cp .env.example .env && nano .env

# Hostname publik VPS (Domainesia) — tanpa http://
PUBLIC_HOST=103-169-206-116.domainesia.io

# URL API untuk frontend nanti (pakai http dulu, belum ada SSL)
API_PUBLIC_URL=http://103-169-206-116.domainesia.io/api/v1

# --- MySQL ---
MYSQL_ROOT_PASSWORD=GANTI_ROOT_PASSWORD_KUAT
MYSQL_DATABASE=progas_wms
MYSQL_USER=progas
MYSQL_PASSWORD=GANTI_PASSWORD_DB_KUAT

# Host "mysql" = nama service di docker-compose
DB_URL=progas:GANTI_PASSWORD_DB_KUAT@tcp(mysql:3306)/progas_wms?charset=utf8mb4&parseTime=True&loc=Local

# --- Backend ---
GO_ENV=production
PORT=3131
DB_MAX_POOL=5

AUTH_TOKEN_EXPIRED_IN_MINUTES=15
REFRESH_TOKEN_EXPIRED_IN_DAYS=7
AUTH_TOKEN_SECRET_KEY=
REFRESH_TOKEN_SECRET_KEY=

# User admin pertama (hanya dibuat jika tabel user masih kosong)
# Hapus atau kosongkan setelah login pertama berhasil
BOOTSTRAP_ADMIN_EMAIL=admin@progas.local
BOOTSTRAP_ADMIN_NAME=Superadmin
BOOTSTRAP_ADMIN_PASSWORD=GANTI_PASSWORD_ADMIN_KUAT
